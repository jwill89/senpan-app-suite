{
  "name": "app-suite-frontend",
  "private": true,
  "version": "3.9.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/",
    "analyze": "cross-env ANALYZE=true vue-tsc -b && cross-env ANALYZE=true vite build",
    "gen:types": "cd ../backend && go run github.com/gzuidhof/tygo@v0.2.21 generate"
  },
  "dependencies": {
    "@awesome.me/kit-46204fb6f1": "^1.0.3",
    "@ckpack/vue-color": "^1.6.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@milkdown/crepe": "^7.21.2",
    "html-to-image": "^1.11.13",
    "markdown-it": "^14.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.1.0",
    "vue3-emoji-picker": "^1.1.8"
  },
  "devDependencies": {
    "@jwill89/eslint-config": "file:eslint-config",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.0.0",
    "eslint": "^10.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "js-beautify": {
      "glob": "^13.0.0"
    }
  }
}
