# Runtime data & local tooling
# Anchored to repo root so the rule doesn't also catch nested dirs like
# plugins/SenpanCompanion/Data/ (git is case-insensitive on Windows).
/data/
/devdata/
.idea/
.vscode/
vendor/
node_modules/
*.sqlite
*.sqlite-shm
*.sqlite-wal
test_cookies.txt

# Built Go binaries
/src/app-suite
/src/app-suite.exe
*.exe

# Frontend (Vite) build output & deps
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
frontend/coverage/

# CI report artifacts (JUnit test reports + golangci-lint Code Quality), produced
# by the pipeline (and if you run the CI commands locally).
/frontend/junit.xml
/src/junit.xml
/src/gl-code-quality-report.json

# Secrets — never commit credentials. systemd EnvironmentFiles, etc.
*.env
!*.env.example

# OS noise
Thumbs.db
.DS_Store
/frontend/src/types/api.generated.ts
/deploy/images/favicon.png
/frontend/public/images/favicon.png
/deploy/images/logo.png
/frontend/public/images/logo.png
/deploy/images/share_banner.png
/frontend/public/images/share_banner.png
/frontend/.npmrc
/.claude/launch.json
/frontend/public/images/called_flourish.svg
/deploy/images/apple-touch-icon.png
/deploy/images/called_flourish.svg
/deploy/images/corner_flourish.svg
/deploy/images/favicon.png
/deploy/images/logo.png
/deploy/images/pwa-192x192.png
/deploy/images/pwa-512x512.png
/deploy/images/pwa-maskable-512x512.png
/frontend/public/images/apple-touch-icon.png
/frontend/public/images/corner_flourish.svg
/frontend/public/images/pwa-192x192.png
/frontend/public/images/pwa-512x512.png
/frontend/public/images/pwa-maskable-512x512.png
/CURRENT_THEMES.css
/scripts/
/frontend/public/sounds/
